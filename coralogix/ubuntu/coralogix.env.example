# Coralogix Configuration Example
# Copy this file to coralogix.env and update with your actual values

# Your Coralogix domain (e.g., app.coralogix.com, app.staging.coralogix.com)
CORALOGIX_DOMAIN=app.coralogix.com

# Your Coralogix private key (starts with cxtp_)
CORALOGIX_PRIVATE_KEY=cxtp_your_private_key_here

# Application name in Coralogix (will be used for all telemetry data)
CORALOGIX_APP_NAME=ubuntu-host

# Subsystem name in Coralogix (will be used for all telemetry data)
CORALOGIX_SUBSYSTEM=system
